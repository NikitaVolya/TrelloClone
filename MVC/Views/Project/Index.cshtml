@model IEnumerable<Domain.Projects.Project>
@{
    ViewData["Title"] = "Projects Page";
}
<div class="container mt-4">
    <h2>Мої проекти</h2>
    <div>
        <div>
            <form asp-action="Create" method="post" class="row g-2">
                <h4>Створити проект</h4>
                <input type="text" name="Title" class="form-control" placeholder="Назва проекту" />
                <input type="text" name="Description" class="form-control" placeholder="Опис проекту" />
                <button type="submit" class="btn btn-primary mt-2">Створити</button>
            </form>
        </div>
        <div class="row">
            @foreach (var project in Model)
            {
                <div class="col-md-4">
                    <a asp-controller="Project" asp-action="Detail" asp-route-id="@project.Id" class="text-decoration-none">
                        <div class="card h-100" style="cursor: pointer; transition: transform 0.2s, box-shadow 0.2s;" onmouseover="this.style.transform='translateY(-4px)'; this.style.boxShadow='0 4px 8px rgba(0,0,0,0.15)';" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='';">
                            <div class="card-body">
                                <h5 class="card-title text-dark">@project.Title</h5>
                                <p class="card-text text-muted">@project.Description</p>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    </div>
</div>


