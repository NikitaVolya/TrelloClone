@model Domain.Boards.Board

@{
    Layout = "_Layout";
    ViewData["Title"] = Model.Title;
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1>@Model.Title</h1>
            <small class="text-muted">Створено: @Model.CreatedAt.ToString("dd.MM.yyyy")</small>
        </div>
        <div>
            <button class="btn btn-sm btn-primary" data-bs-toggle="modal" data-bs-target="#createColumnModal">+ Додати колонку</button>
        </div>
    </div>

    <!-- Kanban Board -->
    <div class="row flex-nowrap overflow-auto" id="kanban-board" style="min-height: 70vh;">
        @foreach (var column in Model.Columns.OrderBy(c => c.Order))
        {
            <div class="col-md-3 mb-3 column-container" draggable="true" data-column-id="@column.Id" data-column-order="@column.Order">
                <div class="card">
                    <div class="card-header d-flex justify-content-between align-items-center" style="background-color: @column.hexColor;">
                        <h5 class="mb-0">@column.Name</h5>
                        <div class="dropdown">
                            <button class="btn btn-sm btn-light dropdown-toggle" type="button" data-bs-toggle="dropdown">⚙️</button>
                            <ul class="dropdown-menu">
                                <li><a class="dropdown-item" href="#" data-bs-toggle="modal" data-bs-target="#editColumnModal-@column.Id">Редагувати</a></li>
                                <li>
                                    <form asp-controller="Column" asp-action="Delete" asp-route-id="@column.Id" method="post">
                                        <button type="submit" class="dropdown-item text-danger" onclick="return confirm('Видалити колонку?')">Видалити</button>
                                    </form>
                                </li>
                            </ul>
                        </div>
                    </div>
                    <div class="card-body column-drop-zone" data-column-id="@column.Id" style="min-height: 200px;">
                        @foreach (var task in Model.Tasks.Where(t => t.ColumnId == column.Id))
                        {
                            <div class="card mb-2 shadow-sm task-card" draggable="true" data-task-id="@task.Id" style="cursor: move;">
                                <div class="card-body p-2" data-bs-toggle="modal" data-bs-target="#taskModal-@task.Id" style="cursor: pointer;">
                                    <h6 class="mb-1">@task.Name</h6>
                                    @if (task.Deadline.HasValue)
                                    {
                                        <small class="text-muted">📅 @task.Deadline.Value.ToString("dd.MM.yyyy")</small>
                                    }
                                    @if (task.Assignees.Any())
                                    {
                                        <div class="mt-1">
                                            <small>👤 @task.Assignees.Count</small>
                                        </div>
                                    }
                                </div>
                            </div>

                            <!-- Task Modal -->
                            <div class="modal fade" id="taskModal-@task.Id" tabindex="-1">
                                <div class="modal-dialog modal-lg">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title">@task.Name</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                        </div>
                                        <div class="modal-body">
                                            <h6>Опис:</h6>
                                            <p>@(task.Description ?? "Немає опису")</p>

                                            <h6>Дедлайн:</h6>
                                            <p>@(task.Deadline.HasValue ? task.Deadline.Value.ToString("dd.MM.yyyy HH:mm") : "Не встановлено")</p>

                                            <h6>Виконавці:</h6>
                                            <div class="mb-3">
                                                @if (task.Assignees.Any())
                                                {
                                                    <ul class="list-group mb-2">
                                                        @foreach (var assignee in task.Assignees)
                                                        {
                                                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                                                Користувач: @assignee.UserId
                                                                <form asp-controller="Task" asp-action="RemoveAssignee" method="post" class="d-inline">
                                                                    <input type="hidden" name="taskId" value="@task.Id" />
                                                                    <input type="hidden" name="userId" value="@assignee.UserId" />
                                                                    <button type="submit" class="btn btn-sm btn-outline-danger">Видалити</button>
                                                                </form>
                                                            </li>
                                                        }
                                                    </ul>
                                                }
                                                else
                                                {
                                                    <p class="text-muted">Виконавці не призначені</p>
                                                }

                                                <form asp-controller="Task" asp-action="AssignUser" method="post" class="d-flex gap-2">
                                                    <input type="hidden" name="taskId" value="@task.Id" />
                                                    @{
                                                        var projectMembers = ViewBag.ProjectMembers as List<string> ?? new List<string>();
                                                    }
                                                    @if (projectMembers.Any())
                                                    {
                                                        <select class="form-select form-select-sm" name="userId" required>
                                                            <option value="">Оберіть користувача</option>
                                                            @foreach (var memberId in projectMembers)
                                                            {
                                                                if (!task.Assignees.Any(a => a.UserId == memberId))
                                                                {
                                                                    <option value="@memberId">@memberId</option>
                                                                }
                                                            }
                                                        </select>
                                                        <button type="submit" class="btn btn-sm btn-success">Призначити</button>
                                                    }
                                                    else
                                                    {
                                                        <p class="text-muted">Немає доступних учасників для призначення</p>
                                                    }
                                                </form>
                                            </div>

                                            <h6>Коментарі:</h6>
                                            <div class="mb-3">
                                                @{
                                                    var taskComments = ViewBag.Comments as List<Domain.Tasks.TaskComment> ?? new List<Domain.Tasks.TaskComment>();
                                                    var currentTaskComments = taskComments.Where(c => c.TaskId == task.Id).ToList();
                                                }
                                                @if (currentTaskComments.Any())
                                                {
                                                    @foreach (var comment in currentTaskComments)
                                                    {
                                                        <div class="mb-2 p-2 border rounded">
                                                            <small class="text-muted">@comment.Sender?.UserName - @comment.CreatedAt.ToString("dd.MM.yyyy HH:mm")</small>
                                                            <p class="mb-0">@comment.Text</p>
                                                        </div>
                                                    }
                                                }
                                                else
                                                {
                                                    <p class="text-muted">Коментарі відсутні</p>
                                                }
                                            </div>

                                            <form asp-controller="Task" asp-action="AddComment" method="post">
                                                <input type="hidden" name="taskId" value="@task.Id" />
                                                <div class="input-group">
                                                    <input type="text" class="form-control" name="text" placeholder="Додати коментар..." required />
                                                    <button type="submit" class="btn btn-primary">Відправити</button>
                                                </div>
                                            </form>
                                        </div>
                                        <div class="modal-footer">
                                            <form asp-controller="Task" asp-action="Delete" asp-route-id="@task.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-danger" onclick="return confirm('Видалити таску?')">Видалити</button>
                                            </form>
                                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Закрити</button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }

                        <button class="btn btn-sm btn-outline-primary w-100 mt-2" data-bs-toggle="modal" data-bs-target="#createTaskModal-@column.Id">+ Додати таску</button>
                    </div>
                </div>

                <!-- Edit Column Modal -->
                <div class="modal fade" id="editColumnModal-@column.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-controller="Column" asp-action="Edit" asp-route-id="@column.Id" method="post">
                                <div class="modal-header">
                                    <h5 class="modal-title">Редагувати колонку</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Назва</label>
                                        <input type="text" class="form-control" name="name" value="@column.Name">
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Колір</label>
                                        <input type="color" class="form-control" name="hexColor" value="@column.hexColor">
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                                    <button type="submit" class="btn btn-primary">Зберегти</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>

                <!-- Create Task Modal for this column -->
                <div class="modal fade" id="createTaskModal-@column.Id" tabindex="-1">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-controller="Task" asp-action="Create" method="post">
                                <input type="hidden" name="BoardId" value="@Model.Id" />
                                <input type="hidden" name="ColumnId" value="@column.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">Створити таску</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Назва</label>
                                        <input type="text" class="form-control" name="Name" required>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Опис</label>
                                        <textarea class="form-control" name="Description" rows="3"></textarea>
                                    </div>
                                    <div class="mb-3">
                                        <label class="form-label">Дедлайн</label>
                                        <input type="datetime-local" class="form-control" name="Deadline">
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                                    <button type="submit" class="btn btn-primary">Створити</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<!-- Create Column Modal -->
<div class="modal fade" id="createColumnModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <form asp-controller="Column" asp-action="Create" method="post">
                <input type="hidden" name="BoardId" value="@Model.Id" />
                <div class="modal-header">
                    <h5 class="modal-title">Створити колонку</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="mb-3">
                        <label class="form-label">Назва</label>
                        <input type="text" class="form-control" name="Name" required>
                    </div>
                    <div class="mb-3">
                        <label class="form-label">Колір</label>
                        <input type="color" class="form-control" name="hexColor" value="#FFFFFF" required>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Скасувати</button>
                    <button type="submit" class="btn btn-primary">Створити</button>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    let draggedTask = null;
    let draggedColumn = null;

    // Task drag and drop
    document.querySelectorAll('.task-card').forEach(card => {
        card.addEventListener('dragstart', function(e) {
            draggedTask = this;
            this.style.opacity = '0.5';
            e.dataTransfer.effectAllowed = 'move';
            e.dataTransfer.setData('text/html', this.innerHTML);
            e.stopPropagation();
        });

        card.addEventListener('dragend', function(e) {
            this.style.opacity = '1';
        });
    });

    // Task drop zones
    document.querySelectorAll('.column-drop-zone').forEach(zone => {
        zone.addEventListener('dragover', function(e) {
            if (draggedTask) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';
                this.style.backgroundColor = '#f0f0f0';
            }
        });

        zone.addEventListener('dragleave', function(e) {
            this.style.backgroundColor = '';
        });

        zone.addEventListener('drop', function(e) {
            if (draggedTask) {
                e.preventDefault();
                e.stopPropagation();
                this.style.backgroundColor = '';

                const taskId = draggedTask.dataset.taskId;
                const newColumnId = this.dataset.columnId;

                fetch('/Task/Move', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `id=${taskId}&columnId=${newColumnId}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.message) {
                        location.reload();
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Помилка при переміщенні таски');
                });
            }
        });
    });

    // Column drag and drop
    document.querySelectorAll('.column-container').forEach(container => {
        container.addEventListener('dragstart', function(e) {
            draggedColumn = this;
            this.style.opacity = '0.5';
            e.dataTransfer.effectAllowed = 'move';
        });

        container.addEventListener('dragend', function(e) {
            this.style.opacity = '1';
            document.querySelectorAll('.column-container').forEach(c => {
                c.style.borderLeft = '';
                c.style.borderRight = '';
            });
        });

        container.addEventListener('dragover', function(e) {
            if (draggedColumn && draggedColumn !== this) {
                e.preventDefault();
                e.dataTransfer.dropEffect = 'move';

                const rect = this.getBoundingClientRect();
                const midpoint = rect.left + rect.width / 2;

                if (e.clientX < midpoint) {
                    this.style.borderLeft = '3px solid #007bff';
                    this.style.borderRight = '';
                } else {
                    this.style.borderRight = '3px solid #007bff';
                    this.style.borderLeft = '';
                }
            }
        });

        container.addEventListener('dragleave', function(e) {
            this.style.borderLeft = '';
            this.style.borderRight = '';
        });

        container.addEventListener('drop', function(e) {
            if (draggedColumn && draggedColumn !== this) {
                e.preventDefault();
                e.stopPropagation();

                this.style.borderLeft = '';
                this.style.borderRight = '';

                const draggedColumnId = draggedColumn.dataset.columnId;
                const draggedOrder = parseInt(draggedColumn.dataset.columnOrder);
                const targetOrder = parseInt(this.dataset.columnOrder);

                const rect = this.getBoundingClientRect();
                const midpoint = rect.left + rect.width / 2;
                const newOrder = e.clientX < midpoint ? targetOrder : targetOrder + 1;

                const boardId = @Model.Id;

                fetch('/Column/Reorder', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `columnId=${draggedColumnId}&newOrder=${newOrder}`
                })
                .then(response => response.json())
                .then(data => {
                    if (data.message) {
                        location.reload();
                    }
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Помилка при переміщенні колонки');
                });
            }
        });
    });
</script>
