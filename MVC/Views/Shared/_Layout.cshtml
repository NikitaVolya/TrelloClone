@{
    string? controller = ViewContext.RouteData.Values["controller"]?.ToString();
    string? action = ViewContext.RouteData.Values["action"]?.ToString();
}

<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — TralloClone</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" />
</head>

<body>

    <div class="app-container">

        <!-- SIDEBAR -->
        <aside class="sidebar">

            <div class="brand">
                <span class="brand-logo">📋</span>
                <span class="brand-name">TralloClone</span>
            </div>

            <!-- USER -->
            <div class="sidebar-user">
                <div class="user-avatar">
                    @{
                        var initial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U";
                    }
                    @initial
                </div>

                <div class="user-info">
                    <div class="user-name">@(User.Identity?.Name ?? "Користувач")</div>
                    <div class="user-role">Учасник</div>
                </div>
            </div>

            <hr />

            <!-- PROJECTS -->
            <div class="sidebar-section-title">Проєкти</div>

            <a class="sidebar-item @(controller == "Project" && action == "Index" ? "active" : "")"
               asp-controller="Project" asp-action="Index">
                Мої проєкти
            </a>

            <a class="sidebar-item @(controller == "Project" && action == "AllProjects" ? "active" : "")"
               asp-controller="Project" asp-action="AllProjects">
                Всі проєкти
            </a>

            <hr />

            <!-- NAVIGATION -->
            <div class="sidebar-section-title">Навігація</div>

            <a class="sidebar-item" asp-controller="Dashboard" asp-action="Index">
                Дашборд
            </a>

            <a class="sidebar-item" asp-controller="Notifications" asp-action="Index">
                Сповіщення
            </a>

            <hr />

            <!-- ACCOUNT -->
            <div class="sidebar-section-title">Акаунт</div>

            <a class="sidebar-item @(controller == "User" && action == "Profile" ? "active" : "")"
               asp-controller="User" asp-action="Profile">
                Налаштування
            </a>

            <a class="sidebar-item danger" asp-controller="Account" asp-action="Logout">
                Вийти
            </a>

        </aside>

        <!-- MAIN -->
        <main class="main-content">
            @RenderBody()
        </main>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>