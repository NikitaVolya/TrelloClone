@model MVC.Models.Account.RegisterViewModel

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <title>Реєстрація</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css"
          rel="stylesheet">

    <link rel="stylesheet" href="~/css/account.css" />
</head>

<body>

    <div class="auth-container">

        <div class="auth-card">

            <h1>Trello Clone</h1>

            <p class="text-muted">
                Створіть акаунт та почніть керувати проєктами
            </p>

            <form asp-action="Register" method="post">

                <div class="mb-3">
                    <input asp-for="UserName"
                           class="form-control"
                           placeholder="Ім'я користувача">
                </div>

                <div class="mb-3">
                    <input asp-for="Email"
                           class="form-control"
                           placeholder="Email">
                </div>

                <div class="mb-3">
                    <input asp-for="Password"
                           class="form-control"
                           placeholder="Пароль">
                </div>

                <div class="mb-3">
                    <input asp-for="ConfirmPassword"
                           class="form-control"
                           placeholder="Підтвердіть пароль">
                </div>

                <button class="btn btn-primary w-100">
                    Зареєструватися
                </button>

            </form>

            <div class="mt-4 text-center">
                Вже є акаунт?
                <a asp-action="Login">Увійти</a>
            </div>

        </div>

    </div>

</body>
</html>
