@model MVC.Models.Account.RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <title>Реєстрація — TrelloClon</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/account.css" />
</head>
<body>
    <div class="auth-container">
        <div class="auth-card">

            <div class="auth-logo">
                <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="32" height="32" rx="8" fill="#5865f2" />
                    <rect x="4" y="8" width="7" height="16" rx="2" fill="white" />
                    <rect x="13" y="8" width="7" height="10" rx="2" fill="white" opacity=".85" />
                    <rect x="22" y="8" width="6" height="13" rx="2" fill="white" opacity=".65" />
                </svg>
                <span class="auth-logo-name">TrelloClon</span>
            </div>

            <h1>Створити акаунт</h1>
            <p class="text-muted">Почніть керувати проєктами вже сьогодні</p>

            <form asp-action="Register" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="mb-3">
                    <input asp-for="UserName" class="form-control" placeholder="Ім'я користувача">
                    <span asp-validation-for="UserName" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <input asp-for="Email" class="form-control" placeholder="Email" autocomplete="email">
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>
                <div class="mb-3">
                    <input asp-for="Password" class="form-control" placeholder="Пароль" autocomplete="new-password">
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>
                <div class="mb-4">
                    <input asp-for="ConfirmPassword" class="form-control" placeholder="Підтвердіть пароль">
                    <span asp-validation-for="ConfirmPassword" class="text-danger"></span>
                </div>
                <button type="submit" class="btn btn-primary w-100">Зареєструватися</button>
            </form>

            <div class="mt-4 text-center">
                Вже є акаунт? <a asp-action="Login">Увійти</a>
            </div>
        </div>
    </div>
</body>
</html>